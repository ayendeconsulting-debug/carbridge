# apps/web — copy to .env.local and fill in.

# Neon POOLED connection (host has -pooler). Used by Prisma Client at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"

# FX margin in basis points (150 = +1.50%)
FX_SPREAD_BPS=150

# Shared secret guarding POST /api/fx/refresh (use a long random string)
FX_REFRESH_SECRET=change-me-long-random

# Upstash Redis — REST credentials (NOT the redis:// TCP string)
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="Axxxxx"
