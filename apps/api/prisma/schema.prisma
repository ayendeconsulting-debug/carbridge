// CarBridge — Prisma schema (SRD §7)
// Money is ALWAYS Decimal (never Float). Prisma's Decimal is backed by decimal.js,
// so values hand off cleanly to @carbridge/shared's cost engine via .toString().

generator client {
  provider = "prisma-client-js"
  // For Railway (Linux) deploys alongside local dev, add the target you deploy on, e.g.:
  // binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Neon POOLED connection (has -pooler), used at runtime
  directUrl = env("DIRECT_URL") // Neon DIRECT connection (no -pooler), used by Prisma Migrate
}

// ------------------------------------------------------------------
// Enums
// ------------------------------------------------------------------

enum UserTier {
  GUEST
  REGISTERED
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  EXPIRED
  CANCELLED
}

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
  STRIPE
}

enum BodyType {
  SUV
  SEDAN
  HATCHBACK
  WAGON
  COUPE
  TRUCK
  VAN
  OTHER
}

enum VehicleStatus {
  DRAFT
  AVAILABLE
  RESERVED
  SOLD
  ARCHIVED
}

enum ShippingMethod {
  RORO
  CONTAINER
}

enum ContainerType {
  SHARED
  SOLE
}

enum FxPair {
  CAD_NGN
}

enum RateLockContext {
  QUOTE
  OFFER
  RESERVATION
}

enum Currency {
  CAD
  NGN
}

enum OfferStatus {
  SUBMITTED
  COUNTERED
  ACCEPTED
  DECLINED
  EXPIRED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  EXPIRED
  CANCELLED
}

enum CarRequestStatus {
  SUBMITTED
  IN_REVIEW
  MATCHED
  FULFILLED
  DECLINED
  CANCELLED
}

// ------------------------------------------------------------------
// Identity & membership
// ------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  tier      UserTier @default(REGISTERED)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
  offers        Offer[]
  reservations  Reservation[]
  favorites     Favorite[]
  rateLocks     RateLock[]
  carRequests   CarRequest[]

  @@index([tier])
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String
  plan        String
  status      SubscriptionStatus @default(ACTIVE)
  provider    PaymentProvider
  providerRef String
  startedAt   DateTime           @default(now())
  expiresAt   DateTime
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, expiresAt])
}

// ------------------------------------------------------------------
// Inventory
// ------------------------------------------------------------------

model Vehicle {
  id                    String         @id @default(cuid())
  make                  String
  model                 String
  year                  Int
  trim                  String?
  bodyType              BodyType
  mileageKm             Int
  conditionGrade        String // e.g. "A", "A-", "B+"
  vin                   String?        @unique
  description           String         @db.Text
  purchasePriceCAD      Decimal        @db.Decimal(12, 2)
  defaultShippingMethod ShippingMethod @default(RORO)
  status                VehicleStatus  @default(DRAFT)
  handlingRateOverride  Decimal?       @db.Decimal(5, 4) // e.g. 0.1200; null = use global 0.12
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  photos         VehiclePhoto[]
  shippingOptions ShippingOption[]
  clearingQuotes ClearingQuote[]
  historyReport  HistoryReport?
  offers         Offer[]
  reservations   Reservation[]
  favorites      Favorite[]
  carRequestMatches CarRequest[] @relation("CarRequestMatch")

  @@index([status])
  @@index([make, model, year])
}

model VehiclePhoto {
  id        String   @id @default(cuid())
  vehicleId String
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, position])
  @@index([vehicleId])
}

model ShippingOption {
  id              String         @id @default(cuid())
  vehicleId       String
  method          ShippingMethod
  containerType   ContainerType? // only for CONTAINER
  costCAD         Decimal        @db.Decimal(12, 2)
  transitWeeksMin Int
  transitWeeksMax Int
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model ClearingQuote {
  id         String    @id @default(cuid())
  vehicleId  String
  costNGN    Decimal   @db.Decimal(18, 2) // manual agent quotation, fixed in naira
  agentName  String
  quoteRef   String?
  quotedAt   DateTime  @default(now())
  validUntil DateTime?
  createdAt  DateTime  @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([validUntil])
}

model HistoryReport {
  id        String   @id @default(cuid())
  vehicleId String   @unique
  hasClaims Boolean  @default(false)
  summary   String?  @db.Text
  reportUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------------------
// FX feed & rate locks
// ------------------------------------------------------------------

model FxRate {
  id            String   @id @default(cuid())
  pair          FxPair   @default(CAD_NGN)
  rawRate       Decimal  @db.Decimal(18, 6) // provider rate (NGN per 1 CAD)
  effectiveRate Decimal  @db.Decimal(18, 6) // post-spread rate actually shown
  source        String
  isStale       Boolean  @default(false)
  fetchedAt     DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([pair, fetchedAt])
}

model RateLock {
  id        String          @id @default(cuid())
  userId    String
  pair      FxPair          @default(CAD_NGN)
  rate      Decimal         @db.Decimal(18, 6)
  context   RateLockContext
  createdAt DateTime        @default(now())
  expiresAt DateTime // typically createdAt + 72h

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers       Offer[]
  reservations Reservation[]

  @@index([userId, expiresAt])
}

// ------------------------------------------------------------------
// Offers & reservations
// ------------------------------------------------------------------

model Offer {
  id              String         @id @default(cuid())
  vehicleId       String
  userId          String
  amount          Decimal        @db.Decimal(18, 2)
  currency        Currency
  shippingMethod  ShippingMethod
  rateLockId      String?
  listingSnapshot Json // frozen price/shipping/clearing/rate at submission
  status          OfferStatus    @default(SUBMITTED)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  rateLock RateLock? @relation(fields: [rateLockId], references: [id])

  @@index([vehicleId])
  @@index([userId])
  @@index([status])
}

model Reservation {
  id             String            @id @default(cuid())
  vehicleId      String
  userId         String
  shippingMethod ShippingMethod
  lockedTotalCAD Decimal           @db.Decimal(14, 2)
  lockedTotalNGN Decimal           @db.Decimal(18, 2)
  rateLockId     String?
  status         ReservationStatus @default(PENDING)
  depositRef     String?
  expiresAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  rateLock RateLock? @relation(fields: [rateLockId], references: [id])

  @@index([vehicleId])
  @@index([userId])
  @@index([status])
}

// ------------------------------------------------------------------
// Car requests (premium "Source a Car")
// ------------------------------------------------------------------

model CarRequest {
  id             String           @id @default(cuid())
  userId         String
  // structured wishlist (all optional — buyer fills what they know)
  make           String?
  model          String?
  yearMin        Int?
  yearMax        Int?
  bodyType       BodyType?
  maxMileageKm   Int?
  // budget, in CAD or NGN (buyer's choice, like an Offer)
  budgetAmount   Decimal          @db.Decimal(18, 2)
  budgetCurrency Currency
  notes          String?          @db.Text
  status         CarRequestStatus @default(SUBMITTED)
  // admin match-back to a candidate listing + note to the buyer
  matchedVehicleId String?
  adminNote        String?        @db.Text
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchedVehicle Vehicle? @relation("CarRequestMatch", fields: [matchedVehicleId], references: [id])

  @@index([userId])
  @@index([status])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  vehicleId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([userId, vehicleId])
  @@index([userId])
}

// ------------------------------------------------------------------
// Audit
// ------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String? // User.id of the admin/actor, if any
  entity    String // e.g. "Vehicle", "FxRate"
  entityId  String
  action    String // e.g. "price.update", "clearing.set"
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorId])
}
