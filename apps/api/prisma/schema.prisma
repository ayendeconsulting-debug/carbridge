// CarBridge — Prisma schema (SRD §7)
// Money is ALWAYS Decimal (never Float). Prisma's Decimal is backed by decimal.js,
// so values hand off cleanly to @carbridge/shared's cost engine via .toString().

generator client {
  provider = "prisma-client-js"
  // For Railway (Linux) deploys alongside local dev, add the target you deploy on, e.g.:
  // binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Neon POOLED connection (has -pooler), used at runtime
  directUrl = env("DIRECT_URL") // Neon DIRECT connection (no -pooler), used by Prisma Migrate
}

// ------------------------------------------------------------------
// Enums
// ------------------------------------------------------------------

enum UserTier {
  GUEST
  REGISTERED
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  EXPIRED
  CANCELLED
}

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
  STRIPE
  MANUAL // admin grant or off-platform (bank) membership payment
}

enum BodyType {
  SUV
  SEDAN
  HATCHBACK
  WAGON
  COUPE
  TRUCK
  VAN
  OTHER
}

enum VehicleStatus {
  DRAFT
  AVAILABLE
  RESERVED
  SOLD
  ARCHIVED
}

enum ShippingMethod {
  RORO
  CONTAINER
}

enum ContainerType {
  SHARED
  SOLE
}

enum FxPair {
  CAD_NGN
}

enum RateLockContext {
  QUOTE
  OFFER
  RESERVATION
}

enum Currency {
  CAD
  NGN
}

enum OfferStatus {
  SUBMITTED
  COUNTERED
  ACCEPTED
  DECLINED
  EXPIRED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  EXPIRED
  CANCELLED
}

enum CarRequestStatus {
  SUBMITTED
  IN_REVIEW
  MATCHED
  FULFILLED
  DECLINED
  CANCELLED
}

// Vehicle spec attributes
enum Transmission {
  AUTOMATIC
  MANUAL
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
}

// Quote / invoice integration (the portfolio quote+invoice platform is the
// external system of record for documents + money; CarBridge stores references
// and a synced status).
enum QuotationStatus {
  DRAFT
  ISSUED
  ACCEPTED
  EXPIRED
  VOID
}

enum InvoiceKind {
  CAR
  MEMBERSHIP
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PART_PAID
  PAID
  VOID
}

enum PaymentSource {
  CARBRIDGE // recorded by an admin inside CarBridge
  PLATFORM // recorded directly in the external platform
  WEBHOOK // delivered to CarBridge by the platform webhook
}

// ------------------------------------------------------------------
// Identity & membership
// ------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  tier      UserTier @default(REGISTERED)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
  offers        Offer[]
  reservations  Reservation[]
  favorites     Favorite[]
  rateLocks     RateLock[]
  carRequests   CarRequest[]
  quotations    Quotation[]
  invoices      Invoice[]
  recordedPayments Payment[]

  @@index([tier])
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String
  plan        String
  status      SubscriptionStatus @default(ACTIVE)
  provider    PaymentProvider
  providerRef String? // null for MANUAL admin grants (no gateway reference)
  invoiceId   String?            @unique // set when granted via a membership invoice
  startedAt   DateTime           @default(now())
  expiresAt   DateTime
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([userId])
  @@index([status, expiresAt])
}

// ------------------------------------------------------------------
// Inventory
// ------------------------------------------------------------------

model Vehicle {
  id                    String         @id @default(cuid())
  make                  String
  model                 String
  year                  Int
  trim                  String?
  bodyType              BodyType
  mileageKm             Int
  conditionGrade        String // e.g. "A", "A-", "B+"
  transmission          Transmission? // nullable: legacy/partial rows tolerated; form requires it
  fuelType              FuelType?
  colour                String?
  vin                   String?        @unique
  description           String         @db.Text
  purchasePriceCAD      Decimal        @db.Decimal(12, 2)
  defaultShippingMethod ShippingMethod @default(RORO)
  status                VehicleStatus  @default(DRAFT)
  handlingRateOverride  Decimal?       @db.Decimal(5, 4) // e.g. 0.1200; null = use global 0.12
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  photos         VehiclePhoto[]
  shippingOptions ShippingOption[]
  clearingQuotes ClearingQuote[]
  historyReport  HistoryReport?
  offers         Offer[]
  reservations   Reservation[]
  favorites      Favorite[]
  carRequestMatches CarRequest[] @relation("CarRequestMatch")
  quotations     Quotation[]

  @@index([status])
  @@index([make, model, year])
}

model VehiclePhoto {
  id        String   @id @default(cuid())
  vehicleId String
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, position])
  @@index([vehicleId])
}

model ShippingOption {
  id              String         @id @default(cuid())
  vehicleId       String
  method          ShippingMethod
  containerType   ContainerType? // only for CONTAINER
  costCAD         Decimal        @db.Decimal(12, 2)
  transitWeeksMin Int
  transitWeeksMax Int
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model ClearingQuote {
  id         String    @id @default(cuid())
  vehicleId  String
  costNGN    Decimal   @db.Decimal(18, 2) // manual agent quotation, fixed in naira
  agentName  String
  quoteRef   String?
  quotedAt   DateTime  @default(now())
  validUntil DateTime?
  createdAt  DateTime  @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([validUntil])
}

model HistoryReport {
  id        String   @id @default(cuid())
  vehicleId String   @unique
  hasClaims Boolean  @default(false)
  summary   String?  @db.Text
  reportUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------------------
// FX feed & rate locks
// ------------------------------------------------------------------

model FxRate {
  id            String   @id @default(cuid())
  pair          FxPair   @default(CAD_NGN)
  rawRate       Decimal  @db.Decimal(18, 6) // provider rate (NGN per 1 CAD)
  effectiveRate Decimal  @db.Decimal(18, 6) // post-spread rate actually shown
  source        String
  isStale       Boolean  @default(false)
  fetchedAt     DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([pair, fetchedAt])
}

model RateLock {
  id        String          @id @default(cuid())
  userId    String
  pair      FxPair          @default(CAD_NGN)
  rate      Decimal         @db.Decimal(18, 6)
  context   RateLockContext
  createdAt DateTime        @default(now())
  expiresAt DateTime // typically createdAt + 72h

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers       Offer[]
  reservations Reservation[]

  @@index([userId, expiresAt])
}

// ------------------------------------------------------------------
// Offers & reservations
// ------------------------------------------------------------------

model Offer {
  id              String         @id @default(cuid())
  vehicleId       String
  userId          String
  amount          Decimal        @db.Decimal(18, 2)
  currency        Currency
  shippingMethod  ShippingMethod
  rateLockId      String?
  listingSnapshot Json // frozen price/shipping/clearing/rate at submission
  status          OfferStatus    @default(SUBMITTED)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  rateLock RateLock? @relation(fields: [rateLockId], references: [id])
  quotations Quotation[]
  reservation Reservation?

  @@index([vehicleId])
  @@index([userId])
  @@index([status])
}

model Reservation {
  id             String            @id @default(cuid())
  vehicleId      String
  userId         String
  shippingMethod ShippingMethod
  lockedTotalCAD Decimal           @db.Decimal(14, 2)
  lockedTotalNGN Decimal           @db.Decimal(18, 2)
  rateLockId     String?
  offerId        String?           @unique // set when reserved from an accepted offer; @unique = one reservation per offer
  status         ReservationStatus @default(PENDING)
  depositRef     String?
  expiresAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  rateLock RateLock? @relation(fields: [rateLockId], references: [id])
  offer    Offer?    @relation(fields: [offerId], references: [id])
  quotations Quotation[]

  @@index([vehicleId])
  @@index([userId])
  @@index([status])
}

// ------------------------------------------------------------------
// Car requests (premium "Source a Car")
// ------------------------------------------------------------------

model CarRequest {
  id             String           @id @default(cuid())
  userId         String
  // structured wishlist (all optional — buyer fills what they know)
  make           String?
  model          String?
  yearMin        Int?
  yearMax        Int?
  bodyType       BodyType?
  maxMileageKm   Int?
  // budget, in CAD or NGN (buyer's choice, like an Offer)
  budgetAmount   Decimal          @db.Decimal(18, 2)
  budgetCurrency Currency
  notes          String?          @db.Text
  status         CarRequestStatus @default(SUBMITTED)
  // admin match-back to a candidate listing + note to the buyer
  matchedVehicleId String?
  adminNote        String?        @db.Text
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchedVehicle Vehicle? @relation("CarRequestMatch", fields: [matchedVehicleId], references: [id])

  @@index([userId])
  @@index([status])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  vehicleId String
  snapshot  Json? // figures frozen when saved (landed total, fx rate, price, status) - diffed on read for the Watching list
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([userId, vehicleId])
  @@index([userId])
}

// ------------------------------------------------------------------
// Quote / invoice (layers after an accepted offer or a reservation)
// ------------------------------------------------------------------

model Quotation {
  id            String          @id @default(cuid())
  number        String?         @unique // native CB-Q-2026-001 (assigned at issue)
  // derived from an accepted offer OR a reservation (exactly one, enforced in code)
  offerId       String?
  reservationId String?
  vehicleId     String
  userId        String
  // frozen figures for the document
  snapshot      Json // line items: purchase / shipping / clearing / handling, CAD + NGN
  fxRate        Decimal         @db.Decimal(18, 6) // locked rate at issue
  totalCAD      Decimal         @db.Decimal(14, 2)
  totalNGN      Decimal         @db.Decimal(18, 2)
  // external system of record (portfolio quote/invoice platform)
  externalQuoteId String?
  externalNumber  String? // human quote number from the platform
  externalUrl     String? // hosted / PDF link
  status        QuotationStatus @default(DRAFT)
  issuedAt      DateTime?
  validUntil    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  offer       Offer?       @relation(fields: [offerId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])
  vehicle     Vehicle      @relation(fields: [vehicleId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  invoices    Invoice[]

  @@index([vehicleId])
  @@index([userId])
  @@index([status])
  @@index([externalQuoteId])
}

model Invoice {
  id          String      @id @default(cuid())
  number      String?     @unique // native CB-INV-2026-001 (assigned at issue)
  kind        InvoiceKind
  userId      String
  quotationId String? // CAR invoices convert from a quotation; MEMBERSHIP has none
  currency    Currency    @default(NGN)
  amount      Decimal     @db.Decimal(18, 2)
  amountPaid  Decimal     @default(0) @db.Decimal(18, 2)
  bankInstructions Json? // official business account shown on the invoice
  // external system of record
  externalInvoiceId String?
  externalNumber    String?
  externalUrl       String?
  status      InvoiceStatus @default(DRAFT)
  issuedAt    DateTime?
  dueAt       DateTime?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  quotation    Quotation?    @relation(fields: [quotationId], references: [id])
  payments     Payment[]
  subscription Subscription? // membership invoice -> the granted subscription

  @@index([userId])
  @@index([status])
  @@index([kind])
  @@index([externalInvoiceId])
}

model Payment {
  id        String        @id @default(cuid())
  invoiceId String
  reference String        @unique // dedup key: bank transfer ref / platform payment ref
  amount    Decimal       @db.Decimal(18, 2)
  currency  Currency      @default(NGN)
  source    PaymentSource
  externalPaymentId String?
  recordedById String? // admin User.id when entered in CarBridge; null for webhook
  note      String?
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  recordedBy User?   @relation(fields: [recordedById], references: [id])

  @@index([invoiceId])
  @@index([recordedById])
}

// ------------------------------------------------------------------
// Document numbering (native CB-Q / CB-INV sequences)
// ------------------------------------------------------------------

/// Per-year, per-kind atomic counter for CB-Q-2026-001 / CB-INV-2026-001.
model DocumentCounter {
  id   String @id @default(cuid())
  kind String // "QUOTE" | "INVOICE"
  year Int
  seq  Int    @default(0)

  @@unique([kind, year])
}

// ------------------------------------------------------------------
// Audit
// ------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String? // User.id of the admin/actor, if any
  entity    String // e.g. "Vehicle", "FxRate"
  entityId  String
  action    String // e.g. "price.update", "clearing.set"
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorId])
}
