# ── Neon (free tier) ────────────────────────────────────────────────
# Both strings come from the Neon Console → Connect.
# POOLED has "-pooler" in the host; DIRECT does not. Keep ?sslmode=require.

# Pooled — used by the app at runtime (Prisma Client)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.us-east-1.aws.neon.tech/carbridge?sslmode=require"

# Direct — used by Prisma Migrate and the seed script
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/carbridge?sslmode=require"
